# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace_with_secure_random
JWT_SECRET_KEY=replace_with_secure_random_jwt

# Database
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/wildfire_db

# Initial admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Email delivery (optional - leave blank to disable email alerts)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=alerts@your-domain.dev
SENDER_NAME=FireScope Alerts
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BASE_DELAY=2.0
DAILY_DIGEST_HOUR=8
WEEKLY_DIGEST_DAY=mon
ALERT_DEDUP_WINDOW_HOURS=24
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
EMAIL_USE_MOCK=false

# Fire news: allowlisted feeds + optional Google Programmable Search
# FIRE_NEWS_CACHE_TTL_SEC=0   # 0 = refetch CAL FIRE / NWS / RSS on every /api/news call (default). Set 900 to cache 15m.
# FALLBACK_SEARCH_CACHE_TTL_SEC=0   # 0 = run CSE on every call when keys set (default). Set 3600 to cache 1h.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ENGINE_ID=
# FALLBACK_MAX_ITEMS=60
# FALLBACK_CSE_MAX_PAGES=10   # up to 10 pages × 10 results per query (CSE daily quota still applies)

# News is persisted in table news_articles (90-day retention by published_at). Apply migrations after deploy.
