# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=replace_with_secure_random
JWT_SECRET_KEY=replace_with_secure_random_jwt

# Database
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/wildfire_db

# Initial admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Email delivery (optional - leave blank to disable email alerts)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=alerts@your-domain.dev
SENDER_NAME=FireWatch Alerts
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BASE_DELAY=2.0
DAILY_DIGEST_HOUR=8
WEEKLY_DIGEST_DAY=mon
ALERT_DEDUP_WINDOW_HOURS=24
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
EMAIL_USE_MOCK=false
